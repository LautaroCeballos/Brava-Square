---
import { getLangFromUrl, useTranslations } from "../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const reviewsTranslations = {
    pt: [
        { name: "Pâmela Coutinho", status: "Local Guide", date: "Há 4 anos no Google", comment: "Excelente pousada! Localização perfeita! Ambiente familiar e aconchegante. Os donos são super prestativos e simpáticos. Fica entre a Praia do Forno e Brava, e a 15 min da Rua das Pedras." },
        { name: "Alex Silva", status: "Local Guide", date: "Há 3 anos no Google", comment: "Lugar muito tranquilo e silencioso. Perto da Rua das Pedras e da Praia do Forno, tudo estava limpo e a piscina excelente. Ótimo custo-benefício! O café da manhã de primeira." },
        { name: "Ludmila S. Araujo", status: "Local Guide", date: "Há 3 anos no Google", comment: "Excelente recepção! O Ronaldo, anfitrião, é super solícito. Bem pertinho da praia, quarto amplo com sala, cozinha e estacionamento." },
    ],
    es: [
        { name: "Pâmela Coutinho", status: "Local Guide", date: "Hace 4 años en Google", comment: "¡Excelente casa de huéspedes! ¡Ubicación perfecta! Ambiente familiar y acogedor. Los dueños son súper amables y simpáticos. Está entre Praia do Forno y Brava, y a 15 min de Rua das Pedras." },
        { name: "Alex Silva", status: "Local Guide", date: "Hace 3 años en Google", comment: "Lugar muy tranquilo y silencioso. Cerca de Rua das Pedras y Praia do Forno, todo estaba limpio y la piscina excelente. ¡Excelente relación calidad-precio! El desayuno de primera." },
        { name: "Ludmila S. Araujo", status: "Local Guide", date: "Hace 3 años en Google", comment: "¡Excelente recepción! Ronaldo, el anfitrión, es súper servicial. Muy cerca de la playa, habitación amplia con sala de estar, cocina y estacionamiento." },
    ],
    en: [
        { name: "Pâmela Coutinho", status: "Local Guide", date: "4 years ago on Google", comment: "Excellent guesthouse! Perfect location! Family and cozy atmosphere. The owners are super helpful and friendly. It is between Praia do Forno and Brava, and 15 min from Rua das Pedras." },
        { name: "Alex Silva", status: "Local Guide", date: "3 years ago on Google", comment: "Very quiet and peaceful place. Close to Rua das Pedras and Praia do Forno, everything was clean and the pool excellent. Great value for money! First-rate breakfast." },
        { name: "Ludmila S. Araujo", status: "Local Guide", date: "3 years ago on Google", comment: "Excellent reception! Ronaldo, the host, is super helpful. Very close to the beach, large room with living room, kitchen and parking." },
    ]
};

const reviews = reviewsTranslations[lang];
---

<section id="opiniones" class="py-24 bg-sand relative overflow-hidden">
    <div
        class="absolute -right-20 -top-20 w-80 h-80 bg-white rounded-full opacity-40 blur-3xl mix-blend-overlay"
    >
    </div>
    <div
        class="absolute -left-20 -bottom-20 w-80 h-80 bg-sage-green rounded-full opacity-20 blur-3xl mix-blend-multiply"
    >
    </div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
        <div class="text-center max-w-2xl mx-auto mb-16">
            <div class="inline-flex items-center justify-center space-x-1 mb-4">
                {
                    [...Array(5)].map(() => (
                        <svg
                            class="w-6 h-6 text-yellow-500"
                            fill="currentColor"
                            viewBox="0 0 20 20"
                        >
                            <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                        </svg>
                    ))
                }
            </div>
            <h2
                class="text-3xl md:text-5xl font-serif font-bold text-primary-green mb-6"
            >
                {t('testimonials.title')} <br />
                <span class="italic font-normal">{t('testimonials.highlight')}</span>
            </h2>
            <p class="text-gray-700 text-lg">
                {t('testimonials.p')}
            </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
            {
                reviews.map((review) => (
                    <div class="bg-white rounded-2xl p-8 shadow-sm hover:shadow-xl transition-shadow duration-300 relative">
                        <svg
                            class="absolute top-6 left-6 w-10 h-10 text-gray-100"
                            fill="currentColor"
                            viewBox="0 0 32 32"
                        >
                            <path d="M9.352 4C4.456 7.456 1 13.12 1 19.36c0 5.088 3.072 8.064 6.624 8.064 3.36 0 5.856-2.688 5.856-5.856 0-3.168-2.208-5.472-5.088-5.472-.576 0-1.344.096-1.536.192.48-3.264 3.552-7.104 6.624-9.024L9.352 4zm16.512 0c-4.896 3.456-8.352 9.12-8.352 15.36 0 5.088 3.072 8.064 6.624 8.064 3.264 0 5.856-2.688 5.856-5.856 0-3.168-2.304-5.472-5.184-5.472-.576 0-1.248.096-1.44.192.48-3.264 3.456-7.104 6.528-9.024L25.864 4z" />
                        </svg>
                        <div class="relative z-10 flex flex-col h-full">
                            <div class="flex items-center mb-6">
                                <div class="w-12 h-12 bg-gray-200 rounded-full flex-shrink-0 overflow-hidden">
                                    <img
                                        src={`https://ui-avatars.com/api/?name=${review.name.replace(" ", "+")}&background=E8DCC4&color=2C5530`}
                                        alt={review.name}
                                        class="w-full h-full object-cover"
                                    />
                                </div>
                                <div class="ml-4">
                                    <h4 class="font-bold text-gray-900">
                                        {review.name}
                                    </h4>
                                    <p class="text-xs text-gray-500">
                                        {review.status} • {review.date}
                                    </p>
                                </div>
                            </div>
                            <p class="text-gray-600 italic leading-relaxed flex-grow">
                                "{review.comment}"
                            </p>
                        </div>
                    </div>
                ))
            }
        </div>

        <div class="mt-12 text-center">
            <a
                href="https://www.google.com/search?q=brava+square+lofts+%26+suites+buzios"
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center text-primary-green hover:text-[#D96C06] font-medium transition-colors"
            >
                {t('testimonials.cta')}
                <svg
                    fill="currentColor"
                    class="w-5 h-5 ml-2"
                    viewBox="0 0 24 24"
                    ><path
                        d="M12.48 10.92v3.28h7.84c-.24 1.84-.853 3.187-1.787 4.133-1.147 1.147-2.933 2.4-6.053 2.4-4.827 0-8.6-3.893-8.6-8.72s3.773-8.72 8.6-8.72c2.6 0 4.507 1.027 5.907 2.347l2.307-2.307C18.747 1.44 16.133 0 12.48 0 5.867 0 .307 5.387.307 12s5.56 12 12.173 12c3.573 0 6.267-1.173 8.373-3.36 2.16-2.16 2.84-5.213 2.84-7.667 0-.76-.053-1.467-.173-2.053H12.48z"
                    ></path></svg
                >
            </a>
        </div>
    </div>
</section>
