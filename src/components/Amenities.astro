---
// src/components/Amenities.astro
const base = import.meta.env.BASE_URL;

const amenitiesList = [
    {
        img: "5.webp",
        title: "Piscina 24 Horas",
        description: "Excelente piscina limpia y disponible todo el día para refrescarse del calor de Búzios.",
        tag: "Destacado",
    },
    {
        img: "13.webp",
        title: "Sala y Cocina",
        description: "Lofts y suítes totalmente equipados con sala de estar y cocina americana para mayor comodidad.",
        tag: "Incluido",
    },
    {
        img: "12.webp",
        title: "Excelente Ubicación",
        description: "A pasos de Praia do Forno y sólo 10 min caminando a Rua das Pedras.",
        tag: "Ubicación",
    },
    {
        img: "2.webp",
        title: "Desayuno Buffet",
        description: "Empiece el día con pan recién hecho, pasteles, y fruta fresca de temporada.",
        tag: "Incluido",
    },
    {
        img: "14.webp",
        title: "Tours y Buggy",
        description: "Asistencia directa con paseos en buggy y barco para que aproveches Búzios al máximo.",
        tag: "Actividades",
    },
    {
        img: "11.webp",
        title: "Ambiente Familiar",
        description: "Entorno seguro, silencioso y amplio ideal para familias con niños.",
        tag: "Familia",
    },
];
---

<section id="servicios" class="py-24 bg-[#1a3a20] relative overflow-hidden">

    <!-- Decorative blobs -->
    <div class="absolute -top-32 -left-32 w-96 h-96 bg-sage-green/20 rounded-full blur-3xl pointer-events-none"></div>
    <div class="absolute -bottom-32 -right-32 w-96 h-96 bg-[#D96C06]/10 rounded-full blur-3xl pointer-events-none"></div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">

        <!-- Heading -->
        <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-4 mb-16">
            <div>
                <span class="text-[#D96C06] font-semibold tracking-wider uppercase text-sm block mb-2">Lo que te espera</span>
                <h2 class="text-3xl md:text-5xl font-serif font-bold text-white leading-tight">
                    Servicios que marcan <br class="hidden md:block"/>
                    <span class="text-sand italic font-normal">la diferencia</span>
                </h2>
            </div>
            <p class="text-white/60 text-base max-w-xs leading-relaxed">
                Descubre por qué nuestros huéspedes nos eligen como su segundo hogar en Búzios.
            </p>
        </div>

        <!-- Cards grid -->
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
            {amenitiesList.map((item, i) => (
                <div class="amenity-card group relative rounded-3xl overflow-hidden cursor-default" style={`--delay: ${i * 80}ms`}>

                    <!-- Full-bleed image -->
                    <div class="relative h-64 overflow-hidden">
                        <img
                            src={`${base}/images/${item.img}`}
                            alt={item.title}
                            loading="lazy"
                            class="w-full h-full object-cover transition-transform duration-700 ease-out group-hover:scale-110"
                        />
                        <!-- Gradient overlay -->
                        <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/30 to-transparent"></div>

                        <!-- Tag chip top-left -->
                        <span class="absolute top-4 left-4 text-xs font-bold tracking-widest uppercase px-3 py-1 rounded-full bg-white/15 backdrop-blur-sm text-white border border-white/20">
                            {item.tag}
                        </span>
                    </div>

                    <!-- Card body -->
                    <div class="bg-white/8 backdrop-blur-sm border-x border-b border-white/10 rounded-b-3xl px-6 py-5 transition-colors duration-300 group-hover:bg-white/14">
                        <h3 class="text-lg font-bold text-white mb-1.5 tracking-wide">{item.title}</h3>
                        <p class="text-white/65 text-sm leading-relaxed">{item.description}</p>

                        <!-- Animated accent line -->
                        <div class="mt-4 h-0.5 w-8 bg-[#D96C06] rounded-full transition-all duration-500 group-hover:w-16"></div>
                    </div>

                </div>
            ))}
        </div>

    </div>
</section>

<style>
    /* subtle entry animation */
    .amenity-card {
        animation: fadeUp 0.5s ease both;
        animation-delay: var(--delay, 0ms);
    }
    @keyframes fadeUp {
        from { opacity: 0; transform: translateY(24px); }
        to   { opacity: 1; transform: translateY(0); }
    }
</style>
