---
// src/components/Amenities.astro
const amenitiesList = [
    {
        icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 12.551A9.957 9.957 0 0012 2C6.477 2 2 6.477 2 12c0 5.523 4.477 10 10 10 2.227 0 4.288-.732 5.926-1.956.195-.15.422-.228.653-.228h1.284a1.137 1.137 0 001.137-1.137v-1.284c0-.231.078-.458.228-.653A9.957 9.957 0 0021 12.55z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 11h.01M12 11h.01M9 11h.01" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 2v2M12 20v2M4.929 4.929l1.414 1.414M17.657 17.657l1.414 1.414M2 12h2M20 12h2M4.929 19.071l1.414-1.414M17.657 6.343l1.414-1.414" /></svg>`,
        title: "Piscina 24 Horas",
        description:
            "Excelente piscina limpia y disponible todo el día para refrescarse del calor de Búzios.",
    },
    {
        icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 21h8" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 17v4" /></svg>`,
        title: "Sala y Cocina",
        description:
            "Lofts y suítes totalmente equipados con sala de estar y cocina americana para mayor comodidad.",
    },
    {
        icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" /></svg>`,
        title: "Excelente Ubicación",
        description:
            "A pasos de Praia do Forno, Praia Brava y sólo 10 min caminando a Rua das Pedras.",
    },
    {
        icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M5 8h14M5 8a2 2 0 110-4h14a2 2 0 110 4M5 8v10a2 2 0 002 2h10a2 2 0 002-2V8m-9 4h4" /></svg>`,
        title: "Desayuno Buffet",
        description:
            "Empiece el día con pan recién hecho, pasteles, y fruta fresca de temporada.",
    },
    {
        icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" /></svg>`,
        title: "Tours y Buggy",
        description:
            "Asistencia directa con paseos en buggy y barco para que aproveches Búzios al máximo.",
    },
    {
        icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 10V3L4 14h7v7l9-11h-7z" /></svg>`,
        title: "Ambiente Familiar",
        description:
            "Camas cómodas, sábanas planchadas y un entorno seguro y silencioso ideal para familias.",
    },
];
---

<section id="servicios" class="py-20 bg-primary-green relative">
    <!-- Subtle pattern background -->
    <div
        class="absolute inset-0 opacity-5"
        style="background-image: radial-gradient(circle at 2px 2px, white 1px, transparent 0); background-size: 24px 24px;"
    >
    </div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
        <div class="text-center max-w-3xl mx-auto mb-16">
            <h2
                class="text-3xl md:text-4xl font-serif font-bold text-white mb-4"
            >
                Servicios que marcan <span class="text-sand italic font-normal"
                    >la diferencia</span
                >
            </h2>
            <p class="text-gray-200 text-lg font-light">
                Descubre por qué nuestros huéspedes valoran nuestro espacio como
                su segundo hogar en la playa.
            </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
            {
                amenitiesList.map((item) => (
                    <div class="bg-white/10 backdrop-blur-sm border border-white/20 p-8 rounded-2xl hover:bg-white/20 transition-all duration-300 group">
                        <div class="w-14 h-14 rounded-full bg-sand text-[#D96C06] flex items-center justify-center mb-6 group-hover:scale-110 group-hover:bg-[#D96C06] group-hover:text-white transition-all">
                            <Fragment set:html={item.icon} />
                        </div>
                        <h3 class="text-xl font-bold text-white mb-3 tracking-wide">
                            {item.title}
                        </h3>
                        <p class="text-white/80 leading-relaxed font-light">
                            {item.description}
                        </p>
                    </div>
                ))
            }
        </div>
    </div>
</section>
