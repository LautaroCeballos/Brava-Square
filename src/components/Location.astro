---
// src/components/Location.astro
---

<section id="ubicacion" class="py-24 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
            <!-- Content Side -->
            <div>
                <span
                    class="text-[#D96C06] font-semibold tracking-wider uppercase text-sm mb-2 block"
                    >Dónde Estamos</span
                >
                <h2
                    class="text-3xl md:text-5xl font-serif font-bold text-primary-green mb-6 leading-tight"
                >
                    La ubicación <span
                        class="text-sage-green italic font-normal"
                        >perfecta</span
                    >
                </h2>

                <p class="text-gray-600 text-lg mb-8 leading-relaxed">
                    Nuestra posada está estratégicamente ubicada para que puedas
                    disfrutar de la tranquilidad sin alejarte de los principales
                    atractivos. Todo a corta distancia a pie.
                </p>

                <div class="space-y-6">
                    <div class="flex items-start">
                        <div class="flex-shrink-0 mt-1">
                            <svg
                                xmlns="http://www.w3.org/2000/svg"
                                class="h-6 w-6 text-[#D96C06]"
                                fill="none"
                                viewBox="0 0 24 24"
                                stroke="currentColor"
                                ><path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    stroke-width="2"
                                    d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"
                                ></path><path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    stroke-width="2"
                                    d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"
                                ></path></svg
                            >
                        </div>
                        <div class="ml-4">
                            <h4 class="text-xl font-bold text-gray-900">
                                Praia do Forno
                            </h4>
                            <p class="text-gray-600 font-lightmt-1">
                                A tan solo 8 minutos caminando. Aguas
                                cristalinas y arena rosada ideal para
                                snorkeling.
                            </p>
                        </div>
                    </div>

                    <div class="flex items-start">
                        <div class="flex-shrink-0 mt-1">
                            <svg
                                xmlns="http://www.w3.org/2000/svg"
                                class="h-6 w-6 text-[#D96C06]"
                                fill="none"
                                viewBox="0 0 24 24"
                                stroke="currentColor"
                                ><path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    stroke-width="2"
                                    d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9"
                                ></path></svg
                            >
                        </div>
                        <div class="ml-4">
                            <h4 class="text-xl font-bold text-gray-900">
                                Rua das Pedras
                            </h4>
                            <p class="text-gray-600 font-light mt-1">
                                10-15 minutos a pie. El centro gastronómico y
                                comercial más famoso de Búzios.
                            </p>
                        </div>
                    </div>

                    <div class="flex items-start">
                        <div class="flex-shrink-0 mt-1">
                            <svg
                                xmlns="http://www.w3.org/2000/svg"
                                class="h-6 w-6 text-[#D96C06]"
                                fill="none"
                                viewBox="0 0 24 24"
                                stroke="currentColor"
                                ><path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    stroke-width="2"
                                    d="M3 21v-4m0 0V5a2 2 0 012-2h6.5l1 1H21l-3 6 3 6h-8.5l-1-1H5a2 2 0 00-2 2zm9-13.5V9"
                                ></path></svg
                            >
                        </div>
                        <div class="ml-4">
                            <h4 class="text-xl font-bold text-gray-900">
                                Praia Brava
                            </h4>
                            <p class="text-gray-600 font-light mt-1">
                                A 12 minutos a pie. Playa con oleaje perfecta
                                para surf y ambiente de beach clubs.
                            </p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Map Side -->
            <div
                class="h-[500px] w-full rounded-2xl overflow-hidden shadow-lg border border-gray-100 relative group"
            >
                <!-- Google Maps embed -->
                <iframe
                    title="Ubicación Brava Square"
                    src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d1839.5955681629282!2d-41.87888802897491!3d-22.758286927551207!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x9655a1bfd6c33b%3A0xcd03ce033c86fbdc!2sBrava%20Square%20LOFTS%20%26%20Su%C3%ADtes!5e0!3m2!1ses-419!2sbr!4v1776265572975!5m2!1ses-419!2sbr"
                    width="100%"
                    height="100%"
                    style="border:0;"
                    allowfullscreen
                    loading="lazy"
                    referrerpolicy="no-referrer-when-downgrade"
                    class="w-full h-full"></iframe>

                <!-- "Open in Google Maps" button overlay (bottom-left) -->
                <a
                    href="https://maps.app.goo.gl/zhLQpZAc1rPthdLV8"
                    target="_blank"
                    rel="noopener noreferrer"
                    class="absolute bottom-4 left-4 inline-flex items-center gap-2 bg-white text-primary-green text-sm font-bold px-4 py-2 rounded-full shadow-lg hover:shadow-xl hover:scale-105 transition-all duration-200 z-10"
                >
                    <svg
                        xmlns="http://www.w3.org/2000/svg"
                        class="h-4 w-4 text-[#D96C06]"
                        fill="currentColor"
                        viewBox="0 0 24 24"
                    >
                        <path
                            d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5S10.62 6.5 12 6.5s2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"
                        ></path>
                    </svg>
                    Abrir en Google Maps
                </a>
            </div>
        </div>
    </div>
</section>
