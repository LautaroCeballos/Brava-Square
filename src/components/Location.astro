---
// src/components/Location.astro
---

<section id="ubicacion" class="py-24 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
            <!-- Content Side -->
            <div>
                <span
                    class="text-[#D96C06] font-semibold tracking-wider uppercase text-sm mb-2 block"
                    >Dónde Estamos</span
                >
                <h2
                    class="text-3xl md:text-5xl font-serif font-bold text-primary-green mb-6 leading-tight"
                >
                    La ubicación <span
                        class="text-sage-green italic font-normal"
                        >perfecta</span
                    >
                </h2>

                <p class="text-gray-600 text-lg mb-8 leading-relaxed">
                    Nuestra posada está estratégicamente ubicada para que puedas
                    disfrutar de la tranquilidad sin alejarte de los principales
                    atractivos. Todo a corta distancia a pie.
                </p>

                <div class="space-y-6">
                    <div class="flex items-start">
                        <div class="flex-shrink-0 mt-1">
                            <svg
                                xmlns="http://www.w3.org/2000/svg"
                                class="h-6 w-6 text-[#D96C06]"
                                fill="none"
                                viewBox="0 0 24 24"
                                stroke="currentColor"
                                ><path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    stroke-width="2"
                                    d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"
                                ></path><path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    stroke-width="2"
                                    d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"
                                ></path></svg
                            >
                        </div>
                        <div class="ml-4">
                            <h4 class="text-xl font-bold text-gray-900">
                                Praia do Forno
                            </h4>
                            <p class="text-gray-600 font-lightmt-1">
                                A tan solo 8 minutos caminando. Aguas
                                cristalinas y arena rosada ideal para
                                snorkeling.
                            </p>
                        </div>
                    </div>

                    <div class="flex items-start">
                        <div class="flex-shrink-0 mt-1">
                            <svg
                                xmlns="http://www.w3.org/2000/svg"
                                class="h-6 w-6 text-[#D96C06]"
                                fill="none"
                                viewBox="0 0 24 24"
                                stroke="currentColor"
                                ><path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    stroke-width="2"
                                    d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9"
                                ></path></svg
                            >
                        </div>
                        <div class="ml-4">
                            <h4 class="text-xl font-bold text-gray-900">
                                Rua das Pedras
                            </h4>
                            <p class="text-gray-600 font-light mt-1">
                                10-15 minutos a pie. El centro gastronómico y
                                comercial más famoso de Búzios.
                            </p>
                        </div>
                    </div>

                    <div class="flex items-start">
                        <div class="flex-shrink-0 mt-1">
                            <svg
                                xmlns="http://www.w3.org/2000/svg"
                                class="h-6 w-6 text-[#D96C06]"
                                fill="none"
                                viewBox="0 0 24 24"
                                stroke="currentColor"
                                ><path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    stroke-width="2"
                                    d="M3 21v-4m0 0V5a2 2 0 012-2h6.5l1 1H21l-3 6 3 6h-8.5l-1-1H5a2 2 0 00-2 2zm9-13.5V9"
                                ></path></svg
                            >
                        </div>
                        <div class="ml-4">
                            <h4 class="text-xl font-bold text-gray-900">
                                Praia Brava
                            </h4>
                            <p class="text-gray-600 font-light mt-1">
                                A 12 minutos a pie. Playa con oleaje perfecta
                                para surf y ambiente de beach clubs.
                            </p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Map Side -->
            <div
                class="h-[500px] w-full rounded-2xl overflow-hidden shadow-lg border border-gray-100 flex items-center justify-center bg-gray-50 relative group"
            >
                <!-- Placeholder map image -->
                <img
                    src="https://images.unsplash.com/photo-1524661135-423995f22d0b?auto=format&fit=crop&w=800&q=80"
                    alt="Mapa de Búzios"
                    class="w-full h-full object-cover grayscale opacity-80 group-hover:grayscale-0 transition-all duration-700"
                />

                <!-- Map Overlay/Pin -->
                <div
                    class="absolute inset-0 bg-primary-green/10 flex flex-col items-center justify-center backdrop-blur-[2px] group-hover:backdrop-blur-none transition-all"
                >
                    <div
                        class="bg-white p-4 rounded-xl shadow-2xl animate-bounce"
                    >
                        <div
                            class="text-[#D96C06] font-bold flex items-center gap-2"
                        >
                            <svg
                                xmlns="http://www.w3.org/2000/svg"
                                class="h-6 w-6"
                                fill="currentColor"
                                viewBox="0 0 24 24"
                                ><path
                                    d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5S10.62 6.5 12 6.5s2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"
                                ></path></svg
                            >
                            <span>Brava Square</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
