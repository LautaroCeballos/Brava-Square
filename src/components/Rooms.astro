---
// src/components/Rooms.astro
const rooms = [
    {
        image: "https://images.unsplash.com/photo-1590490360182-c33d57733427?auto=format&fit=crop&w=800&q=80",
        name: "Loft Familiar",
        description:
            "Espacioso apartamento con sala de estar separada y cocina americana. Ideal para familias buscando confort y practicidad cerca de la playa.",
        capacity: "Hasta 4 personas",
        bed: "1 Matrimonial + 2 Individuales",
        size: "45 m²",
    },
    {
        image: "https://images.unsplash.com/photo-1566665797739-1674de7a421a?auto=format&fit=crop&w=800&q=80",
        name: "Suíte Superior",
        description:
            "Habitación acogedora y luminosa con balcón vistas al jardín. Ropa de cama premium y baño privado.",
        capacity: "Dos personas",
        bed: "1 Matrimonial King",
        size: "25 m²",
    },
    {
        image: "https://images.unsplash.com/photo-1734456416941-416c08f0778e?q=80&w=1170&auto=format&fit=crop&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D",
        name: "Estudio Naturaleza",
        description:
            "Sencillo, limpio y con el verdadero ambiente campestre de Búzios. Pequeña kitchenette y acceso directo a la piscina.",
        capacity: "Dos personas",
        bed: "1 Matrimonial Queen",
        size: "30 m²",
    },
];
---

<section id="alojamiento" class="py-24 bg-white relative">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div
            class="flex flex-col md:flex-row justify-between items-end mb-16 gap-6"
        >
            <div class="max-w-2xl">
                <span
                    class="text-[#D96C06] font-semibold tracking-wider uppercase text-sm mb-2 block"
                    >Nuestras Habitaciones</span
                >
                <h2
                    class="text-3xl md:text-5xl font-serif font-bold text-primary-green leading-tight"
                >
                    Espacios diseñados para tu <span
                        class="text-sage-green italic font-normal"
                        >descanso absoluto</span
                    >
                </h2>
            </div>
            <a
                href="https://wa.me/5522997830238"
                target="_blank"
                class="hidden md:inline-flex items-center gap-2 bg-primary-green text-white px-6 py-3 rounded-full hover:bg-sage-green transition-colors font-medium"
            >
                Ver Tarifas
                <svg
                    xmlns="http://www.w3.org/2000/svg"
                    class="h-5 w-5"
                    viewBox="0 0 20 20"
                    fill="currentColor"
                >
                    <path
                        fill-rule="evenodd"
                        d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z"
                        clip-rule="evenodd"></path>
                </svg>
            </a>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-10">
            {
                rooms.map((room) => (
                    <div class="group bg-soft-white rounded-2xl overflow-hidden shadow-sm hover:shadow-xl transition-all duration-300 border border-gray-100 flex flex-col h-full">
                        <div class="relative h-64 overflow-hidden">
                            <img
                                src={room.image}
                                alt={room.name}
                                class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700"
                            />
                            <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent opacity-80" />
                            <h3 class="absolute bottom-4 left-6 text-2xl font-serif font-bold text-white mb-0">
                                {room.name}
                            </h3>
                        </div>

                        <div class="p-6 flex flex-col flex-grow">
                            <p class="text-gray-600 font-light leading-relaxed mb-6 flex-grow">
                                {room.description}
                            </p>

                            <div class="space-y-3 mb-8">
                                <div class="flex items-center text-sm text-gray-700">
                                    <svg
                                        xmlns="http://www.w3.org/2000/svg"
                                        class="h-5 w-5 text-sage-green mr-3"
                                        fill="none"
                                        viewBox="0 0 24 24"
                                        stroke="currentColor"
                                    >
                                        <path
                                            stroke-linecap="round"
                                            stroke-linejoin="round"
                                            stroke-width="2"
                                            d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"
                                        />
                                    </svg>
                                    {room.capacity}
                                </div>
                                <div class="flex items-center text-sm text-gray-700">
                                    <svg
                                        xmlns="http://www.w3.org/2000/svg"
                                        class="h-5 w-5 text-sage-green mr-3"
                                        fill="none"
                                        viewBox="0 0 24 24"
                                        stroke="currentColor"
                                    >
                                        <path
                                            stroke-linecap="round"
                                            stroke-linejoin="round"
                                            stroke-width="2"
                                            d="M4 8V4m0 0h16v4m-16 0l-1 12h18l-1-12m-16 0h16m-16 0v16"
                                        />
                                    </svg>
                                    {room.bed}
                                </div>
                                <div class="flex items-center text-sm text-gray-700">
                                    <svg
                                        xmlns="http://www.w3.org/2000/svg"
                                        class="h-5 w-5 text-sage-green mr-3"
                                        fill="none"
                                        viewBox="0 0 24 24"
                                        stroke="currentColor"
                                    >
                                        <path
                                            stroke-linecap="round"
                                            stroke-linejoin="round"
                                            stroke-width="2"
                                            d="M4 8V4m0 0h16v4m-16 0l-1 12h18l-1-12m-16 0h16m-16 0v16M8 12v.01M12 12v.01M16 12v.01M8 16v.01M12 16v.01"
                                        />
                                    </svg>
                                    {room.size}
                                </div>
                            </div>

                            <a
                                href="https://wa.me/5522997830238"
                                target="_blank"
                                class="block w-full text-center border-2 border-[#D96C06] text-[#D96C06] hover:bg-[#D96C06] hover:text-white py-3 rounded-xl font-semibold transition-colors"
                            >
                                Reservar este Loft
                            </a>
                        </div>
                    </div>
                ))
            }
        </div>
    </div>
</section>
