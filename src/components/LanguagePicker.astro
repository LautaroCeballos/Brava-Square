---
import { languages } from '../i18n/ui';
import { getLangFromUrl, useTranslatedPath } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const translatePath = useTranslatedPath(lang);

const flags = {
  es: "🇪🇸",
  pt: "🇧🇷",
  en: "🇺🇸"
};
---

<div class="relative group">
  <button 
    class="flex items-center gap-1.5 px-3 py-1.5 rounded-full hover:bg-gray-100 transition-colors border border-transparent hover:border-gray-200"
    id="lang-selector"
  >
    <span class="text-lg leading-none">{flags[lang]}</span>
    <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-gray-400 group-hover:text-gray-600 transition-colors" viewBox="0 0 20 20" fill="currentColor">
      <path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" clip-rule="evenodd" />
    </svg>
  </button>

  <div class="absolute right-0 mt-2 w-32 bg-white rounded-xl shadow-xl border border-gray-100 py-2 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all transform origin-top-right group-hover:translate-y-0 translate-y-[-10px] z-50">
    {Object.entries(languages).map(([code, label]) => (
      <a
        href={translatePath('/', code)}
        class={`flex items-center gap-3 px-4 py-2 text-sm hover:bg-gray-50 transition-colors ${lang === code ? 'text-[#D96C06] font-semibold bg-orange-50/50' : 'text-gray-600'}`}
      >
        <span class="text-base">{flags[code as keyof typeof flags]}</span>
        <span>{label}</span>
      </a>
    ))}
  </div>
</div>

<style>
  /* Ensure the dropdown stays open when moving mouse to it */
  .group:hover .group-hover\:visible {
    visibility: visible;
  }
</style>
